---
import { AvButton, AvCard, AvContainer } from "@ansiversa/components";
import AppShell from "../layouts/AppShell.astro";
import { APP_META } from "../app.meta";
import { buildRootRedirect } from "../lib/redirects";

const rootAppUrl = Astro.locals.rootAppUrl ?? "https://ansiversa.com";
const appUrl = new URL("/app", Astro.url).toString();
const startHref = "/app";
const signInHref = buildRootRedirect(rootAppUrl, "/login", appUrl);

const title = `${APP_META.name} | Ansiversa`;
const description = APP_META.description;

const valueCards = [
  {
    "title": "Professional by default",
    "description": "The workflow is built to feel calm, business-ready, and clear from the first screen."
  },
  {
    "title": "Faster execution",
    "description": "Draft, preview, and copy the proposal in one place so momentum stays on the work instead of the setup."
  },
  {
    "title": "Aligned for production",
    "description": "Proposal Writer follows current Ansiversa layout, app identity, and route standards so it can grow without structural drift."
  }
];
const reasonsToUse = [
  {
    "title": "One clear job",
    "description": "Proposal Writer stays anchored to a single purpose so the future product can remain focused instead of sprawling."
  },
  {
    "title": "Shared Ansiversa standards",
    "description": "The landing page, editor shell, preview workflow, navbar, and footer all follow the current ecosystem baseline."
  },
  {
    "title": "Ready for the next implementation phase",
    "description": "Proposal Writer now ships with a focused V1 proposal workflow and a stable base for later enhancements."
  }
];
---

<AppShell title={title} description={description}>
  <section class="av-section">
    <AvContainer>
      <div class="av-auth-stack-lg">
        <AvCard className="av-auth-card">
          <div class="av-auth-stack-md">
            <div class="av-auth-stack-xs">
              <p class="av-kicker">Career Mini-App</p>
              <h1 class="av-section-title">Generate structured proposals fast.</h1>
              <p class="av-text-soft">
                Proposal Writer gives you a calm, professional workspace for drafting business-ready proposals with live preview, section control, copy-ready output, and local draft retention.
              </p>
            </div>

            <div class="av-row-wrap">
              <AvButton href={startHref}>Open Proposal Writer</AvButton>
              <AvButton href={signInHref} variant="ghost">Sign in</AvButton>
            </div>

            <p class="av-text-soft">
              Live now as a focused V1 business-writing app, with the core editor and preview workflow available directly in the app.
            </p>
          </div>
        </AvCard>

        <div class="grid gap-4 md:grid-cols-3">
          {valueCards.map((card) => (
            <AvCard variant="soft" className="av-auth-stack-sm">
              <h2 class="av-card-heading">{card.title}</h2>
              <p class="av-text-soft">{card.description}</p>
            </AvCard>
          ))}
        </div>

        <div class="grid gap-4 md:grid-cols-[1.1fr_0.9fr]">
          <AvCard variant="soft" className="av-auth-stack-sm">
            <p class="av-kicker">What this app will do</p>
            <h2 class="av-card-heading">Proposal Writer</h2>
            <p class="av-text-soft">
              Proposal Writer is a focused career tool inside Ansiversa. Its first release is being shaped around one practical outcome: Generate structured proposals fast.
            </p>
            <p class="av-text-soft">
              The repo already follows Ansiversa layout, metadata, and route standards, so future work can stay tightly scoped to the actual product workflow.
            </p>
          </AvCard>

          <AvCard className="av-auth-card">
            <div class="av-auth-stack-sm">
              <p class="av-kicker">Category fit</p>
              <h2 class="av-card-heading">Career</h2>
              <p class="av-text-soft">
                Proposal Writer is being positioned with a professional, clean, and trust-building tone so it feels consistent with the
                rest of the Ansiversa ecosystem from the first load.
              </p>
            </div>
          </AvCard>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          {reasonsToUse.map((reason) => (
            <AvCard variant="soft" className="av-auth-stack-sm">
              <p class="av-kicker">Why use it</p>
              <h2 class="av-card-heading">{reason.title}</h2>
              <p class="av-text-soft">{reason.description}</p>
            </AvCard>
          ))}
        </div>

        <AvCard className="av-auth-card">
          <div class="av-auth-stack-md">
            <div class="av-auth-stack-xs">
              <p class="av-kicker">Available now</p>
              <h2 class="av-section-title">The V1 proposal workflow is live and ready to use.</h2>
              <p class="av-text-soft">
                Open the app to draft a proposal, review the live document preview, copy the final text, and continue later with local draft retention.
              </p>
            </div>

            <div class="av-row-wrap">
              <AvButton href={startHref}>Open Proposal Writer</AvButton>
              <AvButton href={signInHref} variant="ghost">Return through Ansiversa</AvButton>
            </div>
          </div>
        </AvCard>
      </div>
    </AvContainer>
  </section>
</AppShell>
